<Window x:Class="SystemCacheCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SystemCacheCleaner"
        xmlns:vm="clr-namespace:SystemCacheCleaner.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="720" Width="1180" 
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- 演示模式 Banner -->
            <RowDefinition Height="Auto" />
            <!-- 头部导航与标题区 -->
            <RowDefinition Height="Auto" />
            <!-- 系统盘空间卡片区 -->
            <RowDefinition Height="Auto" />
            <!-- 主内容展示区 -->
            <RowDefinition Height="*" />
            <!-- 底部操作栏 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. 演示模式提示条 -->
        <Border Grid.Row="0" 
                Background="{StaticResource WarningBannerBackground}" 
                Padding="12,8" 
                Visibility="{Binding IsDemoMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚠️ " FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding DemoModeBannerText}" 
                           Foreground="{StaticResource WarningBannerForeground}" 
                           FontWeight="SemiBold" 
                           FontSize="13" 
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 2. 头部标题区 -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="高效、安全、便捷的 Windows 系统临时文件与浏览器缓存清理方案" 
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#EFF6FF" CornerRadius="4" Padding="10,6">
                        <TextBlock Text="V1.0 正式版" Foreground="{StaticResource PrimaryBrush}" FontWeight="Medium" FontSize="12" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. 系统盘容量概览卡片 -->
        <Grid Grid.Row="2" Margin="24,16,24,8">
            <Border Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Background="#EBF5FF" Margin="0,0,16,0">
                        <TextBlock Text="💾" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="{Binding SystemDiskDisplayText}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding SystemDiskFormattedDetail}" HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>

                        <ProgressBar Height="8" 
                                     Value="{Binding SystemDiskInfo.UsedPercentage, Mode=OneWay}" 
                                     Maximum="100" 
                                     Foreground="{StaticResource PrimaryBrush}" 
                                     Background="#E5E7EB" 
                                     BorderThickness="0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="刷新盘符" 
                                Command="{Binding RefreshDiskCommand}" 
                                Padding="12,6" 
                                Background="Transparent" 
                                BorderBrush="{StaticResource BorderBrush}" 
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 4. 主内容展示区 (M03 扫描结果与 M04 分类选择列表) -->
        <Border Grid.Row="3" Margin="24,8,24,16" 
                Background="{StaticResource CardBackgroundBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="20">
            <Grid>
                <!-- 未开始扫描空状态页面 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="72" Height="72" CornerRadius="36" Background="#F3F4F6" Margin="0,0,0,16">
                        <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="准备就绪，点击“开始扫描”检测垃圾文件" 
                               FontSize="18" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding StatusDescription}" 
                               FontSize="13" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" MaxWidth="500" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>

                <!-- 扫描完成 / 被取消的结果列表 -->
                <Grid Visibility="{Binding HasScanResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 取消警告 Banner (AC-M04-07) -->
                    <Border Grid.Row="0" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12"
                            Visibility="{Binding IsScanCancelled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️ " FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="扫描已被取消，结果可能不完整。为了防止误删，清理按钮已被禁用，请点击“重新扫描”。" 
                                       Foreground="#991B1B" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CategoryResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,10" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- 复选框 -->
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding IsSelected}" 
                                                      VerticalAlignment="Center" 
                                                      Margin="0,0,16,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <!-- 名称与描述 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <Border Background="#F3F4F6" CornerRadius="3" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding RiskLevel}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </Border>
                                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#D97706" Margin="10,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                                            </StackPanel>

                                            <!-- 统计数据 -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding FormattedTotalSize}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding FileCount, StringFormat={}{0} 个文件}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- 5. 底部固定操作栏 -->
        <Border Grid.Row="4" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedSummaryText}" 
                               FontSize="14" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding StatusDescription}" 
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- 取消按钮 (仅扫描中显示) -->
                    <Button Content="取消扫描" 
                            Command="{Binding CancelScanCommand}" 
                            Width="110" Height="40" 
                            Margin="0,0,12,0" 
                            Background="#EF4444" 
                            Foreground="White" 
                            FontWeight="SemiBold" 
                            FontSize="14" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- 查看上次报告按钮 -->
                    <Button Content="查看清理报告" 
                            Command="{Binding ShowReportCommand}" 
                            Width="120" Height="40" 
                            Margin="0,0,12,0" 
                            Background="#F3F4F6" 
                            Foreground="{StaticResource TextPrimaryBrush}" 
                            FontWeight="SemiBold" 
                            FontSize="14" 
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" 
                            Cursor="Hand"
                            Visibility="{Binding HasReport, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- 开始扫描 / 重新扫描按钮 -->
                    <Button Content="开始扫描" 
                            Command="{Binding StartScanCommand}" 
                            Width="120" Height="40" 
                            Margin="0,0,12,0" 
                            Background="{StaticResource PrimaryBrush}" 
                            Foreground="White" 
                            FontWeight="SemiBold" 
                            FontSize="14" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Visibility="{Binding IsNotScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- 立即清理按钮 -->
                    <Button Content="立即清理" 
                            Command="{Binding CleanCommand}" 
                            Width="120" Height="40" 
                            FontWeight="SemiBold" 
                            FontSize="14" 
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#E5E7EB" />
                                        <Setter Property="Foreground" Value="#9CA3AF" />
                                        <Setter Property="Cursor" Value="Arrow" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
