<Application x:Class="SystemCacheCleaner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SystemCacheCleaner">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- 全局样式与颜色变量 -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0066CC" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#0052A3" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F4F6F9" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="WarningBannerBackground" Color="#FEF3C7" />
        <SolidColorBrush x:Key="WarningBannerForeground" Color="#92400E" />
    </Application.Resources>
</Application>
