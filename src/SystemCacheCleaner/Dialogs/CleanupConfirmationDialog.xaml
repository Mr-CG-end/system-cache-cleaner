<Window x:Class="SystemCacheCleaner.Dialogs.CleanupConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认执行缓存清理" 
        Height="380" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- 头部图标与标题 -->
            <RowDefinition Height="Auto" />
            <!-- 中部说明信息与卡片 -->
            <RowDefinition Height="*" />
            <!-- 底部操作按钮 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. 头部标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="40" Height="40" CornerRadius="20" Background="#FEF3C7" Margin="0,0,12,0">
                <TextBlock Text="⚠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="准备开始清理缓存文件" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="请核对以下待清理项与预估释放的空间" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- 2. 信息卡片 -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel VerticalAlignment="Center">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="清理类别：" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock x:Name="TxtCategoryCount"
                                   Text="0 类"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock x:Name="TxtCategoryNames"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <TextBlock Text="包含文件总数：" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="TxtFileCount" Text="0 个文件" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                </Grid>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,12">
                    <TextBlock Text="预计可释放空间：" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtExpectedSpace" Text="0 B" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" />
                </Grid>

                <TextBlock Text="💡 提示：只读、无权限或被其他进程排他性占用的文件将被自动安全跳过。" 
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- 3. 按钮操作区 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" 
                    IsCancel="True"
                    Width="100" Height="36" 
                    Margin="0,0,12,0" 
                    Background="Transparent" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Foreground="{StaticResource TextPrimaryBrush}" 
                    Cursor="Hand" />

            <Button Content="确认清理" 
                    IsDefault="True"
                    Click="OnConfirmClick"
                    Width="110" Height="36" 
                    Background="{StaticResource PrimaryBrush}" 
                    Foreground="White" 
                    FontWeight="SemiBold" 
                    BorderThickness="0" 
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
