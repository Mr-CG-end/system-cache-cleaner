<Window x:Class="SystemCacheCleaner.Dialogs.CleanupReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="清理报告" 
        Height="480" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- 头部状态 Banner -->
            <RowDefinition Height="Auto" />
            <!-- 数据统计卡片 -->
            <RowDefinition Height="Auto" />
            <!-- 异常/跳过/失败原因摘要列表 -->
            <RowDefinition Height="*" />
            <!-- 底部操作按钮 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. 头部 Banner -->
        <Border x:Name="BannerBorder" Grid.Row="0" CornerRadius="6" Padding="14,10" Margin="0,0,0,16" Background="#ECFDF5" BorderBrush="#10B981" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtBannerIcon" Text="✅ " FontSize="16" VerticalAlignment="Center" />
                <TextBlock x:Name="TxtBannerTitle" Text="清理完成！" FontSize="15" FontWeight="Bold" Foreground="#047857" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- 2. 统计卡片 -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="成功删除" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtSuccessCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="自动跳过" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtSkipCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="删除失败" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtFailCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="已释放空间" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TxtFreedBytes" Text="0 B" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <TextBlock x:Name="TxtTimeRange"
                           Grid.Row="1"
                           Grid.ColumnSpan="4"
                           Margin="0,14,0,0"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </Border>

        <!-- 3. 详细说明/异常列表 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="详细日志与异常摘要：" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />

            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LstLogs">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="6,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FilePath}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="11" Foreground="#EF4444" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 4. 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" 
                    IsCancel="True"
                    Width="100" Height="36" 
                    Margin="0,0,12,0" 
                    Background="Transparent" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Foreground="{StaticResource TextPrimaryBrush}" 
                    Cursor="Hand" />

            <Button Content="重新扫描" 
                    IsDefault="True"
                    Click="OnRescanClick"
                    Width="110" Height="36" 
                    Background="{StaticResource PrimaryBrush}" 
                    Foreground="White" 
                    FontWeight="SemiBold" 
                    BorderThickness="0" 
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
